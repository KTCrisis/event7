# --- Supabase Cloud ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-jwt-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt-key

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Encryption ---
ENCRYPTION_KEY=your-fernet-key-here

# --- FastAPI ---
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000

# --- Confluent Cloud (optionnel, pour tests) ---
CONFLUENT_SR_URL=https://psrc-xxxxx.region.gcp.confluent.cloud
CONFLUENT_SR_API_KEY=your-sr-api-key
CONFLUENT_SR_API_SECRET=your-sr-api-secret
OLLAMA_HOST=https://ollama.com
OLLAMA_MODEL=
OLLAMA_API_KEY=