 ============================================================
# event7 — Backend Configuration
# ============================================================
# Copy this file to .env and fill in the required values.
# Docker Compose sets DATABASE_URL and REDIS_URL automatically.
# ============================================================
 
# --- Encryption (REQUIRED) ---
# Fernet key for encrypting registry credentials at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
 
# --- Database (REQUIRED) ---
# Database mode. Always 'postgresql' for self-hosted.
DB_PROVIDER=postgresql
# PostgreSQL connection string. Docker Compose sets this automatically.
# For manual setup: postgresql://user:pass@host:5432/event7
# DATABASE_URL=postgresql://event7:event7@localhost:5432/event7
 
# --- Redis ---
# Redis connection URL. Docker Compose sets this automatically.
# REDIS_URL=redis://localhost:6379/0
 
# --- Auth ---
# Enable JWT authentication. Set to 'false' for local evaluation.
AUTH_ENABLED=false
 
# --- CORS ---
# Allowed CORS origins as a JSON array. Add your frontend URL if not localhost.
CORS_ORIGINS=["http://localhost:3000"]
 
# --- AI Agent (optional) ---
# Ollama API URL for the AI Agent.
# Leave empty to disable AI Agent.
# Local Ollama:  http://host.docker.internal:11434
# Ollama Cloud:  https://ollama.com
OLLAMA_HOST=
# LLM model name. Required if OLLAMA_HOST is set.
# Local:  llama3.1:8b
# Cloud:  kimi-k2.5:cloud
OLLAMA_MODEL=
# API key for Ollama Cloud or OpenAI-compatible providers.
# Leave empty for local Ollama.
OLLAMA_API_KEY=
 
# --- App ---
# Environment name. 'development' enables debug mode.
APP_ENV=development
# Enable debug logging (loguru).
APP_DEBUG=true